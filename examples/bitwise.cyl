# Bitwise operators demonstration in Cylium

func main() -> int
    int a = input() as int
    int b = input() as int
    
    echo("AND: " + (a & b))
    echo("OR: " + (a | b))
    echo("XOR: " + (a ^ b))
    echo("Left Shift: "  + (a << 2))
    echo("Right Shift: " + (a >> 2))
    
    return 0
end