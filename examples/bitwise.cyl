# Bitwise operators demonstration in Cylium

func main() -> number
    number a = input() as number
    number b = input() as number
    
    echo("AND: " + (a & b))
    echo("OR: " + (a | b))
    echo("XOR: " + (a ^ b))
    echo("Left Shift: "  + (a << 2))
    echo("Right Shift: " + (a >> 2))
    
    return 0
end