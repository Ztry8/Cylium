# Sieve of Eratosthenes in Cylium

func main() -> int 
    int n = input() as int
    bool[] p = [n + 1; true]

    p[0] = false
    p[1] = false

    for i from 2 to n
        if p[i]
            int j = i * i 
            while j <= n 
                p[j] = false
                j += i
            end
        end
    end

    for i from 2 to n 
        if p[i]
            echo(i)
        end
    end

    return 0
end